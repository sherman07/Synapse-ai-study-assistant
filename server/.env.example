SYNAPSE_DATA_API_PORT=3001
SYNAPSE_DATA_CORS_ORIGINS=http://127.0.0.1:5175,http://localhost:5175

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=synapse
MYSQL_USER=synapse_app
MYSQL_PASSWORD=replace_with_your_local_password
MYSQL_CONNECTION_LIMIT=10

# Local development only. Lets the browser send X-Synapse-User-Id/Client-Id
# headers as an identity instead of a verified Supabase token. MUST stay unset
# or false in every deployed environment; otherwise any caller can impersonate
# any user by choosing a header value. The code default is now false (fail-safe).
ALLOW_LOCAL_DEMO_AUTH=true
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_SCHEMA=public

# Auth email delivery is configured on the FastAPI backend, not this data API.

# Stripe secrets stay on this Express server. Never copy these into frontend/config.js.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Set the same value in backend/.env as SYNAPSE_INTERNAL_API_TOKEN
# so FastAPI can mirror generated content to this data API.
SYNAPSE_INTERNAL_API_TOKEN=replace_with_a_long_random_value

# AI Broadcast durable job metadata defaults.
# Script writing uses GPT 5.4 Mini; spoken playback uses the same OpenAI Realtime voice stack as Voice Tutor.
BROADCAST_SCRIPT_MODEL=gpt-5.4-mini
BROADCAST_TTS_PROVIDER=openai
BROADCAST_TTS_MODEL=gpt-4o-mini-tts
