{
  "name": "synapse-data-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:setup": "node src/db/applySchema.js",
    "db:reset": "node src/db/resetLocalData.js",
    "check": "find src tests -name '*.js' -print0 | xargs -0 -n1 node --check && node --test tests/*.test.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "mysql2": "^3.11.5"
  }
}
