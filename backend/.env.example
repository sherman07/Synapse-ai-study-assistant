OPENAI_API_KEY=__ADD_YOUR_OPENAI_API_KEY__
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# Optional: Gemini text generation is configured in backend/.env.gemini
# so it stays separate from your OpenAI/GPT key. Gemini can use ADC via Vertex AI.

# -------------------------
# Backend runtime
# -------------------------
SYNAPSE_PUBLIC_BACKEND_URL=http://127.0.0.1:8001
SYNAPSE_CORS_ALLOW_ORIGINS=http://127.0.0.1:5175,http://localhost:5175
OPENAI_TIMEOUT_SECONDS=240
ANALYSIS_MAX_SECONDS=300
MAX_UPLOAD_BYTES=104857600
MAX_SOURCE_CHARS=90000

# -------------------------
# Data API / MySQL bridge
# -------------------------
SYNAPSE_DATA_API_INTERNAL_URL=http://127.0.0.1:3001
SYNAPSE_DATA_API_TIMEOUT_SECONDS=5
SYNAPSE_INTERNAL_API_TOKEN=replace_with_the_same_internal_token_as_server_env

# -------------------------
# OpenAI models
# -------------------------
OPENAI_ANALYSIS_MODEL=gpt-5.4-mini
OPENAI_COMPREHENSIVE_MODEL=gpt-5.4-mini
OPENAI_DEEP_MODEL=gpt-5.4-mini
OPENAI_DETAILED_MODEL=gpt-5.4-mini
OPENAI_STANDARD_MODEL=gpt-5.4-mini
OPENAI_FOCUSED_MODEL=gpt-5.4-mini
OPENAI_BRIEF_MODEL=gpt-5.4-mini
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_FALLBACK_MODEL=gpt-5-mini
OPENAI_MINDMAP_MODEL=gpt-5-mini
OPENAI_TITLE_MODEL=gpt-5-mini

# -------------------------
# Audio / realtime
# -------------------------
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin

# -------------------------
# Image guide generation
# -------------------------
VISUAL_IMAGE_GUIDE_RENDERER=openai
OPENAI_VISUAL_IMAGE_GUIDE_MODEL=gpt-image-1.5
OPENAI_VISUAL_IMAGE_GUIDE_SIZE=1024x1536
OPENAI_VISUAL_IMAGE_GUIDE_QUALITY=medium
# Optional exact-text fallback renderer for open-economy posters. Keep false
# when you want the normal Generate image guide button to call GPT Image 1.5.
VISUAL_IMAGE_GUIDE_DOMAIN_LOCAL=false

# -------------------------
# Notes generation quality / speed
# -------------------------
CONTROLLED_INLINE_VISUAL_MODE=true
CONTROLLED_MAX_VISUALS=8
CONTROLLED_OUTPUT_TOKENS=12000
CONTROLLED_MAX_SOURCE_CONTEXT_CHARS=90000
CONTROLLED_MAX_CHARS_PER_SOURCE=16000
CONTROLLED_VISUAL_CARD_TOKENS=2600
CONTROLLED_VISUAL_RENDER_DPI=200
CONTROLLED_MAX_PDF_PAGES_PER_SOURCE=10
CONTROLLED_MAX_PPTX_SLIDES_PER_SOURCE=10
CONTROLLED_INCLUDE_SOURCE_CARDS=false

RICH_INLINE_MIN_OUTPUT_UNITS=5200
ADVANCED_NOTES_MIN_TABLES=2
ADVANCED_NOTES_MIN_HEADINGS=8
ENABLE_CONDITIONAL_NOTE_EXPANSION=true

# -------------------------
# Visual extraction
# -------------------------
ENABLE_PPTX_SLIDE_RENDER=false
ENABLE_PPTX_SVG_FALLBACK_RENDER=true
ENABLE_SOURCE_PPTX_PREVIEW_RENDER=true
ENABLE_LOCAL_PPTX_APP_RENDER=false

SOURCE_PREVIEW_RENDER_DPI=200
SOURCE_PREVIEW_MAX_SLIDES=60
SOURCE_PREVIEW_MAX_PDF_PAGES=80
SOURCE_PREVIEW_MAX_EMBEDDED_IMAGES=80
SOURCE_PREVIEW_PPTX_CONVERT_TIMEOUT=90

MAX_VISUAL_IMAGES_PER_SOURCE=6
MAX_MULTI_SOURCE_VISUAL_IMAGES=18
MULTISOURCE_VISUAL_GALLERY_LIMIT=10
VISUAL_ARGUMENT_CARD_LIMIT=8
VISUAL_ARGUMENT_TOKENS=900
VISUAL_ARGUMENT_CONTEXT_CHARS=50000

RELEVANT_VISUAL_MODE=true
RELEVANT_VISUAL_POOL_LIMIT=16
RELEVANT_VISUAL_MIN_SCORE=6
PDF_VISUAL_CANDIDATE_LIMIT=16

# -------------------------
# Local image quality
# -------------------------
IMAGE_RENDER_DPI=200
IMAGE_ENHANCE_LOCAL=true
IMAGE_OUTPUT_FORMAT=png
IMAGE_MAX_WIDTH=2200
IMAGE_ENHANCE_CONTRAST=1.12
IMAGE_ENHANCE_SHARPNESS=1.18
IMAGE_UNSHARP_RADIUS=1.1
IMAGE_UNSHARP_PERCENT=105
IMAGE_UNSHARP_THRESHOLD=3
IMAGE_JPEG_QUALITY=92
USE_EXTERNAL_IMAGE_UPSCALE=false

# -------------------------
# Multi-source analysis
# -------------------------
ENABLE_MULTI_SOURCE_DIGESTS=true
MULTISOURCE_SOURCE_CHARS=120000
MULTISOURCE_SOURCE_CARD_CHARS=50000
MULTISOURCE_SOURCE_DIGEST_TOKENS=2800
MULTISOURCE_DIGEST_CONTEXT_CHARS=90000
MULTISOURCE_CONNECTION_TOKENS=6000
MULTISOURCE_CONNECTION_REPAIR_TOKENS=7000
MULTISOURCE_REQUIRED_CONNECTION_POINTS=5

# -------------------------
# Single-source analysis
# -------------------------
COMPREHENSIVE_MAX_OUTPUT_TOKENS=9000
COMPREHENSIVE_SOURCE_CHARS=120000
FOCUSED_MAX_OUTPUT_TOKENS=1800
FOCUSED_SOURCE_CHARS=9000
STANDARD_MAX_OUTPUT_TOKENS=4200
STANDARD_SOURCE_CHARS=24000
DETAILED_MAX_OUTPUT_TOKENS=8000
DETAILED_SOURCE_CHARS=65000

# -------------------------
# Tutor
# -------------------------
ENABLE_TUTOR_WEB_RESEARCH=true
MAX_TUTOR_SEARCH_RESULTS=4
MAX_TUTOR_RESEARCH_CHARS=9000
VOICE_TUTOR_HISTORY_LIMIT=32
VOICE_TUTOR_CONTEXT_CHARS=22000
VOICE_TUTOR_TOKENS=2600
VOICE_TUTOR_REALTIME_CONTEXT_CHARS=18000

# -------------------------
# Audio / video / YouTube source parsing
# -------------------------
MAX_AUDIO_BYTES=25165824
MAX_VIDEO_BYTES=62914560
MAX_VIDEO_FRAMES=8
YOUTUBE_EXTRACT_FRAMES=false

# -------------------------
# Quiz / flashcards / learning path
# -------------------------
QUIZ_MAX_QUESTIONS=30
QUIZ_TEMPERATURE=0.45
QUIZ_CONTEXT_CHARS=70000
QUIZ_GENERATION_TOKENS=6500
FLASHCARD_MAX_CARDS=80
FLASHCARD_GENERATION_TOKENS=8500
TIMELINE_MAX_EVENTS=16
TIMELINE_TEMPERATURE=0.25
TIMELINE_GENERATION_TOKENS=6500
TIMELINE_CHECK_TOKENS=1600

# -------------------------
# Token / cache optimization
# -------------------------
ENABLE_TOKEN_OPTIMIZATION=true
COMPACT_SYSTEM_PROMPTS=true
MINIFY_MODEL_JSON=true
MINIFY_CACHE_JSON=true
LOG_TOKEN_USAGE=true
ADD_JSON_MINIFY_HINT=true
ANALYSIS_CACHE_TTL_SECONDS=604800
