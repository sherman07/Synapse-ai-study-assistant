# Separate Gemini text-generation settings.
# Copy this file to backend/.env.gemini, configure your Google Cloud project,
# then restart the backend.
#
# Keep OpenAI keys in backend/.env. Keep Gemini keys here.

# Set to gemini when you want Synapse text generation to use Gemini while keeping
# the same prompt modes, source context, validators, and frontend API shape.
AI_TEXT_PROVIDER=gemini

# Option A: Google Application Default Credentials through Vertex AI.
GEMINI_AUTH_MODE=adc
GEMINI_PROJECT_ID=your-google-cloud-project-id
GEMINI_LOCATION=us-central1

# Option B: Gemini API key through Google's OpenAI-compatible endpoint.
# To use this instead, change GEMINI_AUTH_MODE to api_key, set GEMINI_API_KEY,
# and change model names below from google/gemini-* to gemini-*.
# GEMINI_AUTH_MODE=api_key
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Text models used by the existing note/tutor/quiz/timeline call paths.
# ADC/Vertex uses google/gemini-* model names.
GEMINI_MODEL=google/gemini-2.5-flash
GEMINI_ANALYSIS_MODEL=google/gemini-2.5-flash
GEMINI_COMPREHENSIVE_MODEL=google/gemini-2.5-flash
GEMINI_DEEP_MODEL=google/gemini-2.5-flash
GEMINI_DETAILED_MODEL=google/gemini-2.5-flash
GEMINI_STANDARD_MODEL=google/gemini-2.5-flash
GEMINI_FOCUSED_MODEL=google/gemini-2.5-flash
GEMINI_BRIEF_MODEL=google/gemini-2.5-flash
GEMINI_CHAT_MODEL=google/gemini-2.5-flash
GEMINI_FALLBACK_MODEL=google/gemini-2.5-flash
GEMINI_MINDMAP_MODEL=google/gemini-2.5-flash
GEMINI_TITLE_MODEL=google/gemini-2.5-flash

# API-key mode model-name form:
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_ANALYSIS_MODEL=gemini-2.5-flash
# GEMINI_COMPREHENSIVE_MODEL=gemini-2.5-flash
# GEMINI_DEEP_MODEL=gemini-2.5-flash
# GEMINI_DETAILED_MODEL=gemini-2.5-flash
# GEMINI_STANDARD_MODEL=gemini-2.5-flash
# GEMINI_FOCUSED_MODEL=gemini-2.5-flash
# GEMINI_BRIEF_MODEL=gemini-2.5-flash
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_FALLBACK_MODEL=gemini-2.5-flash
# GEMINI_MINDMAP_MODEL=gemini-2.5-flash
# GEMINI_TITLE_MODEL=gemini-2.5-flash
